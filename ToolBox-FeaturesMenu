-- SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

-- VARIABLES
local lp = Players.LocalPlayer
local guiParent = lp:WaitForChild("PlayerGui")
local currentTab = "Player"

-- QUẢN LÝ LOGIC & TABS
local FeatureLogic = {
	["Fling"] = {
	tab = "Player",
	logic = function(on)
		-- cleanup connection cũ nếu có
		if _G.FlingConnection then
			_G.FlingConnection:Disconnect()
			_G.FlingConnection = nil
		end

		if on then
			_G.FlingConnection = RunService.Heartbeat:Connect(function()
				local char = lp.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				if not hrp then return end

				local vel = hrp.Velocity
				hrp.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
				RunService.RenderStepped:Wait()
				hrp.Velocity = vel
			end)
		end
	end
},
["Anti-Collision"] = {
		tab = "Player",
		logic = function(on)
			_G.AntiCollide = on
			if on then
				task.spawn(function()
					while _G.AntiCollide do
						for _, otherPlayer in ipairs(Players:GetPlayers()) do
							if otherPlayer ~= lp and otherPlayer.Character then
								for _, part in ipairs(otherPlayer.Character:GetDescendants()) do
									if part:IsA("BasePart") then
										part.CanCollide = false
									end
								end
							end
						end
						task.wait(0.1) -- Đợi một chút để tránh giật lag
					end
				end)
			end
		end
	},

	["Print Hello"] = {
		tab = "World",
		logic = function(on)
			if on then print("Hello World! 🌎") end
		end
	}
}

-- TRẠNG THÁI HỆ THỐNG
_G.Features = {}
for name, _ in pairs(FeatureLogic) do _G.Features[name] = false end

-- CLEANUP OLD UI
if guiParent:FindFirstChild("CustomToolboxUI") then guiParent.CustomToolboxUI:Destroy() end

-- UI INITIALIZATION
local screenGui = Instance.new("ScreenGui", guiParent)
screenGui.Name = "CustomToolboxUI"
screenGui.ResetOnSpawn = false

local menu = Instance.new("Frame", screenGui)
menu.Name = "MenuContainer"
menu.Size = UDim2.new(1, 0, 1, 0)
menu.BackgroundTransparency = 1
menu.Visible = false

-- TOGGLE BUTTON
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.Name = "MenuToggle"
toggleBtn.Text = "🛠️"
toggleBtn.Size = UDim2.new(0, 50, 0, 50)
toggleBtn.Position = UDim2.new(0, 10, 0, 10)
toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 18
toggleBtn.Draggable = true 
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)

-- TAB LIST (Bên trái)
local tabList = Instance.new("Frame", menu)
tabList.Size = UDim2.new(0, 160, 1, 0)
tabList.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
tabList.BackgroundTransparency = 0.6
local tabLayout = Instance.new("UIListLayout", tabList)
tabLayout.Padding = UDim.new(0, 0)

-- FEATURE LIST (Bên phải)
local featureList = Instance.new("Frame", menu)
featureList.Size = UDim2.new(0, 160, 1, 0)
featureList.Position = UDim2.new(1, -160, 0, 0)
featureList.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
featureList.BackgroundTransparency = 0.6

local featurePadding = Instance.new("UIPadding", featureList)
featurePadding.PaddingTop = UDim.new(0, 20)

local featureLayout = Instance.new("UIListLayout", featureList)
featureLayout.Padding = UDim.new(0, 10)
featureLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center -- Căn giữa khung
featureLayout.VerticalAlignment = Enum.VerticalAlignment.Top

-- HÀM CẬP NHẬT TAB
local function refreshView()
	for _, btn in ipairs(featureList:GetChildren()) do
		if btn:IsA("TextButton") then
			local data = FeatureLogic[btn.Name]
			btn.Visible = (data and data.tab == currentTab)
		end
	end
end

-- TẠO NÚT TAB (Mở rộng chiều dọc)
local function createTab(name)
	local container = Instance.new("Frame", tabList)
	container.Size = UDim2.new(1, 0, 0, 60) -- Tăng từ 41 lên 60
	container.BackgroundTransparency = 1
	
	local btn = Instance.new("TextButton", container)
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.Text = name
	btn.Font = Enum.Font.SourceSans 
	
	btn.TextSize = 20 
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.BackgroundTransparency = 1
	
	local divider = Instance.new("Frame", container)
	divider.Size = UDim2.new(1, 0, 0, 1)
	divider.Position = UDim2.new(0, 0, 1, 0)
	divider.BackgroundColor3 = Color3.new(1, 1, 1)
	divider.BackgroundTransparency = 0.7
	divider.BorderSizePixel = 0


	btn.MouseButton1Click:Connect(function()
		currentTab = name
		refreshView()
	end)
end

-- TẠO NÚT TÍNH NĂNG (Căn giữa chuẩn)
local function createFeatureBtn(name, order)
	local btn = Instance.new("TextButton", featureList)
	btn.Name = name
	btn.Size = UDim2.new(0, 140, 0, 35)
	btn.LayoutOrder = order
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 14
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.BackgroundTransparency = 1
	btn.Text = name .. ": ❌" -- Bỏ khoảng trống lùi đầu dòng
	btn.TextXAlignment = Enum.TextXAlignment.Center -- Căn giữa chữ trong nút

	btn.MouseButton1Click:Connect(function()
		_G.Features[name] = not _G.Features[name]
		local isOn = _G.Features[name]
		btn.Text = name .. (isOn and ": ✅" or ": ❌")
		if FeatureLogic[name] then FeatureLogic[name].logic(isOn) end
	end)
end

-- KHỞI TẠO
createTab("Player")
createTab("World")

local orderCount = 1
for name, _ in pairs(FeatureLogic) do
	createFeatureBtn(name, orderCount)
	orderCount = orderCount + 1
end

-- EVENTS
toggleBtn.MouseButton1Click:Connect(function() menu.Visible = not menu.Visible end)

lp.CharacterAdded:Connect(function(char)
	char:WaitForChild("Humanoid").Died:Connect(function()
		for name, _ in pairs(_G.Features) do
			_G.Features[name] = false
			local btn = featureList:FindFirstChild(name)
			if btn then btn.Text = name .. ": ❌" end
		end
	end)
end)

refreshView()
